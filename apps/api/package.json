{
  "name": "@bridgeed/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore node_modules src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --filter @bridgeed/shared build && vitest run"
  },
  "dependencies": {
    "@bridgeed/shared": "workspace:*",
    "@google/genai": "^1.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "vitest": "^4.0.18"
  }
}
