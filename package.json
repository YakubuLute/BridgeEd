{
  "name": "bridgeed",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "dev": "pnpm --filter @bridgeed/shared build && turbo run dev --filter=@bridgeed/shared --filter=@bridgeed/api --filter=@bridgeed/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "prettier": "^3.5.1",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  }
}
